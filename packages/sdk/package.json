{
  "name": "@ynab-toolkit/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "test": "bun test --parallel",
    "smoke": "test -n \"$YNAB_API_KEY\" || (echo 'Error: YNAB_API_KEY is required. Set it in your .env file.' >&2 && exit 1) && bun test tests/smoke.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
